{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mix.local/schemas/bank-statement-extraction.schema.json",
  "title": "Bank Statement Extraction",
  "type": "object",
  "required": [
    "document_type",
    "institution_name",
    "statement_period",
    "account_holder_names",
    "accounts",
    "transactions",
    "summary",
    "confidence"
  ],
  "properties": {
    "document_type": {
      "const": "bank_statement"
    },
    "institution_name": {
      "type": "string"
    },
    "statement_period": {
      "type": "object",
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" }
      }
    },
    "account_holder_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mailing_address": {
      "type": ["string", "null"]
    },
    "accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["account_label", "opening_balance", "closing_balance"],
        "properties": {
          "account_label": { "type": "string" },
          "account_number_last4": { "type": ["string", "null"] },
          "currency": { "type": "string", "default": "CAD" },
          "opening_balance": { "type": "number" },
          "closing_balance": { "type": "number" }
        }
      }
    },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "description", "amount", "direction"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "description": { "type": "string" },
          "amount": { "type": "number" },
          "direction": { "enum": ["credit", "debit"] },
          "category": {
            "enum": [
              "income",
              "transfer",
              "housing",
              "debt_payment",
              "cash_withdrawal",
              "nsf",
              "overdraft",
              "large_deposit",
              "fee",
              "tax",
              "other"
            ]
          },
          "account_label": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_credits",
        "total_debits",
        "average_monthly_income",
        "nsf_count",
        "overdraft_count",
        "large_deposit_count"
      ],
      "properties": {
        "total_credits": { "type": "number" },
        "total_debits": { "type": "number" },
        "average_monthly_income": { "type": "number" },
        "recurring_income_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description_pattern": { "type": "string" },
              "frequency": { "type": "string" },
              "average_amount": { "type": "number" },
              "occurrences": { "type": "integer" }
            }
          }
        },
        "nsf_count": { "type": "integer" },
        "overdraft_count": { "type": "integer" },
        "large_deposit_count": { "type": "integer" },
        "large_deposits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string", "format": "date" },
              "description": { "type": "string" },
              "amount": { "type": "number" },
              "explanation_required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": ["overall", "ocr", "table_extraction", "transaction_parsing"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 1 },
        "ocr": { "type": "number", "minimum": 0, "maximum": 1 },
        "table_extraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "transaction_parsing": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "broker_review_required": {
      "type": "boolean"
    },
    "review_reasons": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
